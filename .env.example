# Google Analytics Measurement ID (format: G-XXXXXXXXXX)
# Dapatkan dari https://analytics.google.com → Admin → Data Streams → pilih stream → Measurement ID
NEXT_PUBLIC_GA_ID=

# Google Search Console Verification (format: xXXXXX_XXXXXXXXXXXX_XXXXXXXX)
# Dapatkan dari https://search.google.com/search-console → Add property → HTML tag method
# Copy nilai content dari meta tag: <meta name="google-site-verification" content="...">
NEXT_PUBLIC_GOOGLE_VERIFICATION=
